rules_version = '2';

// FitLog Firestore security rules.
//
// Access model:
//   • Only the authenticated, email-verified owner may read or write their data.
//   • Only the single known document path is matched — every other path is
//     denied by default (no matching allow rule = deny in Firestore).
//   • Writes are validated: unknown keys are rejected, key arrays are size-capped,
//     and scalar types are checked to prevent malformed / oversized documents.
//
// Deploy: firebase deploy --only firestore:rules
//         (requires firebase.json + .firebaserc in the repo root)

service cloud.firestore {
  match /databases/{database}/documents {

    // The one document per user that the app reads and writes.
    match /users/{userId}/data/fitlog {
      allow read:  if isVerifiedOwner(userId);
      allow write: if isVerifiedOwner(userId) && isValidFitlogDoc();
    }

    // Everything else — subcollections, other paths — denied by default.
  }

  // ── Helper functions ──────────────────────────────────────────────────────

  /** Caller must be the document's owner AND have a verified email address. */
  function isVerifiedOwner(userId) {
    return request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email_verified == true;
  }

  /**
   * Validates the top-level shape of the fitlog document on every write.
   *
   * Checks:
   *   1. No unknown top-level keys (allow-list).
   *   2. Scalar fields have the correct type and reasonable length.
   *   3. Array fields are lists and are capped to prevent document-size abuse
   *      (Firestore hard limit is 1 MiB; these caps keep the doc well below it).
   */
  function isValidFitlogDoc() {
    let d = request.resource.data;

    // ── 1. Top-level field allow-list ───────────────────────────────────────
    let allowed = [
      'sessionName', 'exercises', 'meals', 'activeDate',
      'history', 'streak', 'lastWorkoutDate', 'muscleGroupHistory',
      'cardioSessions', 'customFoods', 'profile', 'goal', 'weightLog',
      'units', 'notificationsEnabled'
    ];

    // ── 2. Scalar type + length guards ──────────────────────────────────────
    let scalarsOk =
         (!('sessionName'          in d) || (d.sessionName is string         && d.sessionName.size()  <= 100))
      && (!('streak'               in d) || d.streak is number)
      && (!('units'                in d) || d.units in ['metric', 'imperial'])
      && (!('notificationsEnabled' in d) || d.notificationsEnabled is bool)
      && (!('activeDate'           in d) || d.activeDate == null || d.activeDate is string)
      && (!('lastWorkoutDate'      in d) || d.lastWorkoutDate == null || d.lastWorkoutDate is string);

    // ── 3. Array size guards ─────────────────────────────────────────────────
    let arraysOk =
         (!('history'        in d) || (d.history        is list && d.history.size()        <= 500))
      && (!('exercises'      in d) || (d.exercises      is list && d.exercises.size()      <= 50))
      && (!('meals'          in d) || (d.meals          is list && d.meals.size()          <= 20))
      && (!('cardioSessions' in d) || (d.cardioSessions is list && d.cardioSessions.size() <= 500))
      && (!('weightLog'      in d) || (d.weightLog      is list && d.weightLog.size()      <= 365))
      && (!('customFoods'    in d) || (d.customFoods    is list && d.customFoods.size()    <= 200));

    return d.keys().hasOnly(allowed) && scalarsOk && arraysOk;
  }
}
